# Smartbuilder MVP - Environment Configuration Template
# Copy this file to .env and fill in your API keys

# ============================================
# Core Configuration
# ============================================
# API Security - Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# AI Provider Configuration
# ============================================
# Choose your primary AI provider: "openai", "anthropic", or "gemini"
AI_PROVIDER=gemini

# Enable fallback to other providers if primary fails
ENABLE_FALLBACK=True

# ============================================
# OpenAI Configuration
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ============================================
# Anthropic Claude Configuration
# ============================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# Google Gemini Configuration
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ============================================
# External Data Sources & Tools
# ============================================
# SERPAPI for web search
SERPAPI_API_KEY=your_serpapi_key_here

# TestSprite for automated testing
TESTSPRITE_API_KEY=your_testsprite_key_here

# E2B for code execution
E2B_API_KEY=your_e2b_api_key_here

# Base44 for market research
BASE44_API_KEY=your_base44_api_key_here

# ============================================
# GitHub Integration (Source Control)
# ============================================
# Smartbuilder uses a GitHub App for version control.
# Create one at: https://github.com/settings/apps
GITHUB_APP_ID=your_github_app_id
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_if_used

# ============================================
# Persistence (Supabase)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ============================================
# Advanced AI Settings
# ============================================
TEMPERATURE=0.7
MAX_TOKENS=4096
TOP_P=1.0
